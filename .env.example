# Shared defaults
POLICYPAY_STORAGE_DRIVER=sqlite
POLICYPAY_SQLITE_PATH=./data/policypay.sqlite

# Service ports (all > 20000)
CONTROL_PLANE_PORT=24010
RELAYER_PORT=24020
INDEXER_PORT=24030
DASHBOARD_PORT=24040

# Service-to-service base URLs
CONTROL_PLANE_BASE_URL=http://127.0.0.1:24010
RELAYER_BASE_URL=http://127.0.0.1:24020
INDEXER_BASE_URL=http://127.0.0.1:24030

# Optional per-service storage override
# CONTROL_PLANE_STORAGE_DRIVER=sqlite
# CONTROL_PLANE_SQLITE_PATH=./data/policypay.sqlite
# RELAYER_STORAGE_DRIVER=sqlite
# RELAYER_SQLITE_PATH=./data/policypay.sqlite
# INDEXER_STORAGE_DRIVER=sqlite
# INDEXER_SQLITE_PATH=./data/policypay.sqlite
